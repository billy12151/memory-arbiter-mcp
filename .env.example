# Local SQLite path. Defaults to ./memory_arbiter.sqlite3
MEMORY_ARBITER_DB_PATH=./memory_arbiter.sqlite3

# Append-only fallback used when SQLite is not writable.
MEMORY_ARBITER_BACKUP_JSONL=./memory_arbiter.backup.jsonl

# Optional policy file for tool routing by client/agent.
MEMORY_ARBITER_POLICY=./examples/openclaw.agent-policy.json

# Durable user config. Prefer this for sqlite-vec/model settings so client
# reinstall or migration does not overwrite them.
# MEMORY_ARBITER_CONFIG=~/.config/memory-arbiter/config.json

# Client identity defaults: codex, zcode, openclaw, or custom.
MEMORY_ARBITER_CLIENT=codex
MEMORY_ARBITER_AGENT_ID=default
MEMORY_ARBITER_WORKSPACE=default

# Enable sqlite-vec probing. If unavailable, the server degrades automatically.
MEMORY_ARBITER_ENABLE_SQLITE_VEC=true
MEMORY_ARBITER_VEC_DIM=768

# Legacy GGUF model-path fallback. For v0.5.0 auto-embedding, prefer
# embedding.model_path in ~/.config/memory-arbiter/config.json.
# MEMORY_ARBITER_GGUF=/path/to/embedding-model.gguf
